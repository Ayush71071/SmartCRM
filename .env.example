# ---------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# With Neon: DATABASE_URL = pooled connection string, DIRECT_URL = the same
# host without "-pooler" (used for schema pushes/migrations).
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartcrm?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/smartcrm?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate a secret with: npx auth secret
# ---------------------------------------------------------------------------
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com -> Credentials -> OAuth Client ID)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# OpenAI (AI Lead Scoring, Email Generator, Meeting Summaries, Sales
# Insights, Sentiment Analysis, Task Suggestions)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""

# ---------------------------------------------------------------------------
# Resend (email reminders / notifications)
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="SmartCRM <onboarding@resend.dev>"

# ---------------------------------------------------------------------------
# UploadThing (document / avatar uploads)
# ---------------------------------------------------------------------------
UPLOADTHING_TOKEN=""

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
